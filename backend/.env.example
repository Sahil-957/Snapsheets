APP_NAME=Bulk OCR Extractor API
DEBUG=false
CORS_ORIGINS=["https://snapsheets.vercel.app","https://www.snapsheets.vercel.app","http://localhost:3000","http://127.0.0.1:3000"]
STORAGE_ROOT=storage
TESSERACT_CONFIDENCE_THRESHOLD=80
MAX_WORKERS=4
BATCH_SIZE=10
UPLOAD_MAX_FILES=10000
UPLOAD_MAX_PART_SIZE_MB=25
EXPORT_RETENTION_DAYS=7
TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\google-vision-service-account.json
GOOGLE_APPLICATION_CREDENTIALS_JSON=
